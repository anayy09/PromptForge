# Primary (Navigator) OpenAI-compatible endpoint (server-only; never exposed to
# the client). Serves the models tagged source: "navigator" in the registry.
MODEL_API_BASE_URL=
MODEL_API_KEY=

# OpenRouter endpoint for the models tagged source: "openrouter". The base URL
# defaults to https://openrouter.ai/api/v1 when left blank; only the key is
# required. Either provider may be configured alone; models whose provider is
# missing are hidden in the UI and rejected by the API routes.
OPENROUTER_API_BASE_URL=
OPENROUTER_API_KEY=

# Access gate for public deploys. When set, every route requires a login at
# /login before use, so the endpoints above cannot be abused by anyone
# who finds the URL. Leave blank for local dev to disable the gate.
# (APP_SHARED_SECRET is still accepted as an alias for backward compatibility.)
APP_ACCESS_PASSWORD=
